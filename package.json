{
  "name": "projungle",
  "version": "0.1.0",
  "description": "An infinite forest for organizing dropped files into browsable projects",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.example.projungle",
    "productName": "ProJungle",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
